<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1>All Employees</h1>

    <a href="/employee/new">
        <button>Add New Employee</button>
    </a>
    <br>
    <br>
    <table border="1">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Position</th>
            <th>Salary</th>
        </tr>

        <% for (const employee of employees) { %>
            <tr>
                <td>
                    <%= employee.username %>
                </td>
                <td>
                    <%= employee.email %>
                </td>
                <td>
                    <%= employee.department %>
                </td>
                <td>
                    <%= employee.position %>
                </td>
                <td>
                    <%= employee.salary %>
                </td>
            </tr>
            <% } %>
    </table>
</body>

</html>